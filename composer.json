{
    "name": "devgeek/beacon-admin",
    "type": "symfony-bundle",
    "description": "Dashboard Admin panel for Symfony",
    "keywords": ["admin", "dashboard", "symfony", "bundle"],
    "homepage": "https://github.com/devgeek/beacon-admin",
    "license": "MIT",
    "authors": [
        {
            "name": "Florian",
            "email": "flopau53@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^3.10|^4.4",
        "doctrine/doctrine-bundle": "^2.18|^3.2",
        "doctrine/orm": "^2.20|^3.6",
        "league/flysystem": "^3.10",
        "roave/security-advisories": "dev-latest",
        "symfony/asset": "^7.4|^8.0",
        "symfony/config": "^7.4|^8.0",
        "symfony/dependency-injection": "^7.4|^8.0",
        "symfony/deprecation-contracts": "^3.0",
        "symfony/doctrine-bridge": "^7.4|^8.0",
        "symfony/event-dispatcher": "^7.4|^8.0",
        "symfony/filesystem": "^7.4|^8.0",
        "symfony/form": "^7.4|^8.0",
        "symfony/framework-bundle": "^7.4|^8.0",
        "symfony/http-foundation": "^7.4|^8.0",
        "symfony/http-kernel": "^7.4|^8.0",
        "symfony/intl": "^7.4|^8.0",
        "symfony/property-access": "^7.4|^8.0",
        "symfony/security-bundle": "8.2.x-dev",
        "symfony/stimulus-bundle": "^2.9.1|^3.0",
        "symfony/string": "^7.4|^8.0",
        "symfony/translation": "^7.4|^8.0",
        "symfony/twig-bridge": "^7.4|^8.0",
        "symfony/twig-bundle": "^7.4|^8.0",
        "symfony/uid": "^7.4|^8.0",
        "symfony/ux-twig-component": "^2.32|^3.0",
        "symfony/validator": "^7.4|^8.0",
        "twig/extra-bundle": "^3.23",
        "twig/html-extra": "^3.23",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.2",
        "doctrine/doctrine-fixtures-bundle": "^3.4|^4.0",
        "friendsofphp/php-cs-fixer": "^3.75",
        "infection/infection": "^0.29",
        "laravel/pao": "1.x-dev",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.1|^12.0",
        "psr/log": "^1.0|^2.0|^3.0",
        "rector/rector": "^2.0",
        "symfony/asset-mapper": "^7.4|^8.0",
        "symfony/browser-kit": "^7.4|^8.0",
        "symfony/css-selector": "^7.4|^8.0",
        "symfony/debug-bundle": "^7.4|^8.0",
        "symfony/dom-crawler": "^7.4|^8.0",
        "symfony/expression-language": "^7.4|^8.0",
        "symfony/finder": "^7.4|^8.0",
        "symfony/phpunit-bridge": "^7.4|^8.0",
        "symfony/process": "^7.4|^8.0",
        "symfony/var-dumper": "^7.4|^8.0",
        "symfony/web-link": "^7.4|^8.0",
        "symfony/yaml": "8.2.x-dev",
        "vincentlanglet/twig-cs-fixer": "^3.10",
        "zenstruck/foundry": "^2.3"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Devgeek\\BeaconAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devgeek\\BeaconAdmin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "minimum-stability": "dev"
}
