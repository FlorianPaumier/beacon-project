parameters:
    level: 6
    paths:
        - src/
        - tests/
    excludePaths:
        - tests/Fixtures/
    bootstrapFiles:
        - vendor/autoload.php
        - tests/bootstrap.php
    ignoreErrors:
        # PHPUnit: `$this->assertX()` is standard, static checks apply in test context
        - '#Dynamic call to static method#'
        # Tests: assertInstanceOf with known type is harmless
        - '#Call to method.*assertInstanceOf\(\).*will always evaluate to true#'
