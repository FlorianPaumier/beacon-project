{% extends '@BeaconAdmin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
    <div class="beacon-dashboard">
        <div class="beacon-dashboard-header">
            <h1 class="beacon-dashboard-title">{{ beacon_admin_config('title')|default('Dashboard') }}</h1>
            <p class="beacon-dashboard-subtitle">{{ 'Welcome back'|trans }}{% if app.user is not null %}, {{ app.user.userIdentifier }}{% endif %}</p>
        </div>

        <div class="beacon-widget-grid" {{ stimulus_controller('@beacon-admin/dashboard') }}>
            {% for widget in widgets %}
                <div class="beacon-widget beacon-widget--cols-{{ widget.getCols() }}"
                    {{ stimulus_target('@beacon-admin/dashboard', 'widget') }}
                    data-widget-name="{{ widget.getName() }}"
                >
                    <div class="beacon-widget__header">
                        <h2 class="beacon-widget__title">{{ widget.getLabel() }}</h2>
                    </div>
                    <div class="beacon-widget__body">
                        {{ widget.render()|raw }}
                    </div>
                </div>
            {% else %}
                <div class="beacon-empty-state">
                    <p>{{ 'No widgets configured.'|trans }}</p>
                    <p>{{ 'Create a service implementing DashboardWidgetInterface and tag it with beacon_admin.widget.'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
