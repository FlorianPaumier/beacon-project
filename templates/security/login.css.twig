.beacon-login-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 1rem;
    background: var(--beacon-bg, #f1f5f9);
}

.beacon-login-card {
    width: 100%;
    max-width: 24rem;
    background: var(--beacon-card-bg, #ffffff);
    border-radius: var(--beacon-radius, 0.5rem);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    padding: 2rem;
}

.beacon-login-header {
    text-align: center;
    margin-bottom: 1.5rem;
}

.beacon-login-brand {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--beacon-primary, #2563eb);
}

.beacon-login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
