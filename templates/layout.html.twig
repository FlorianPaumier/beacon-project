<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}"
      data-theme="{{ beacon_admin_theme() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ beacon_admin_config('title')|default('Beacon Admin') }}{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📡</text></svg>">
    <script>!function(){try{var t=localStorage.getItem("beacon-theme"),d=localStorage.getItem("beacon-color-scheme");if(t)document.documentElement.setAttribute("data-theme",t);if("dark"===d)document.documentElement.classList.add("dark")}catch(e){}}()</script>
    {% block stylesheets %}
        {% include '@BeaconAdmin/_styles.html.twig' %}
    {% endblock %}

    {% block brand_styles %}
        <style>
            :root {
                --beacon-brand-primary: {{ beacon_admin_brand().primary_color }};
                --beacon-brand-accent: {{ beacon_admin_brand().accent_color }};
            }
        </style>
    {% endblock %}
</head>
<body class="beacon-body"
      data-controller="@beacon-admin/theme @beacon-admin/keyboard-shortcuts"
      data-themes="{{ beacon_admin_themes()|json_encode|e('html_attr') }}">
    {% block body %}
        <div class="beacon-admin-layout">
            {% block sidebar %}
                {% include '@BeaconAdmin/components/sidebar.html.twig' %}
            {% endblock %}

            <div class="beacon-admin-content">
                {% block header %}
                    {% include '@BeaconAdmin/components/header.html.twig' %}
                {% endblock %}

                {% block flash_messages %}
                    {% include '@BeaconAdmin/components/alert.html.twig' %}
                {% endblock %}

                <main class="beacon-admin-main">
                    {% block breadcrumbs %}
                        {% include '@BeaconAdmin/components/breadcrumbs.html.twig' %}
                    {% endblock %}

                    {% block content %}{% endblock %}
                </main>

                {% block footer %}
                    {% include '@BeaconAdmin/components/footer.html.twig' %}
                {% endblock %}
            </div>
        </div>

        {% include '@BeaconAdmin/components/global_search.html.twig' with {
            searchUrl: path('beacon_admin_global_search')
        } %}
    {% endblock %}

    {% block javascripts %}
        {% include '@BeaconAdmin/_scripts.html.twig' %}
    {% endblock %}
</body>
</html>
