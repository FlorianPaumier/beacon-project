<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}"{% if beacon_theme().dark_mode %} data-bs-theme="auto"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ beacon_config().title }}{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📡</text></svg>">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('bundles/beaconadmin/beacon.css') }}">
    {% endblock %}
</head>
<body>
    <div class="beacon-layout">
        {% block sidebar %}
            <aside class="beacon-sidebar">
                <div class="beacon-brand">
                    {% if beacon_config().logo %}
                        <img src="{{ asset(beacon_config().logo) }}" alt="{{ beacon_config().title }}" class="beacon-logo">
                    {% else %}
                        <span class="beacon-title">{{ beacon_config().title }}</span>
                    {% endif %}
                </div>
                <nav class="beacon-nav">
                    {{ beacon_menu()|raw }}
                </nav>
            </aside>
        {% endblock %}

        <main class="beacon-main">
            {% block header %}
                <header class="beacon-header">
                    <h1>{% block page_title %}{% endblock %}</h1>
                    <div class="beacon-actions">
                        {% block header_actions %}{% endblock %}
                    </div>
                </header>
            {% endblock %}

            {% block flash_messages %}
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="beacon-alert beacon-alert--{{ type }}" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
            {% endblock %}

            {% block content %}{% endblock %}
        </main>
    </div>

    {% block javascripts %}
        <script src="{{ asset('bundles/beaconadmin/beacon.js') }}" type="module" defer></script>
    {% endblock %}
</body>
</html>
