<header class="beacon-header">
    <div class="beacon-header-left">
        <button class="beacon-header-mobile-toggle"
                data-action="@beacon-admin/sidebar#toggle"
                aria-label="{{ 'beacon_admin.nav.toggle_navigation'|trans({}, 'beacon_admin') }}">
            <span class="beacon-icon">☰</span>
        </button>
        <h1 class="beacon-page-title">{% block page_title %}{% endblock %}</h1>
    </div>

    <div class="beacon-header-right">
        <button class="beacon-global-search-trigger"
                data-action="@beacon-admin/keyboard-shortcuts#openGlobalSearch"
                aria-label="Search (Ctrl+K)"
                title="Search (Ctrl+K)">
            <span class="beacon-icon">&#x1F50D;</span>
            <span class="beacon-global-search-trigger__hint">Ctrl+K</span>
        </button>

        <select class="beacon-theme-select"
                data-action="change->@beacon-admin/theme#setTheme"
                aria-label="{{ 'beacon_admin.nav.select_theme'|trans({}, 'beacon_admin') }}">
            {% for name, path in beacon_admin_themes() %}
                <option value="{{ name }}" {{ name == beacon_admin_theme() ? 'selected' : '' }}>
                    {{ name|capitalize }}
                </option>
            {% endfor %}
        </select>

        <button class="beacon-theme-toggle"
                data-action="@beacon-admin/theme#toggleColorScheme"
                aria-label="{{ 'beacon_admin.nav.toggle_dark_mode'|trans({}, 'beacon_admin') }}">
            <span class="beacon-icon">🌓</span>
        </button>

        {% if app.user is not null %}
            <div class="beacon-user-menu">
                <span class="beacon-user-name">{{ app.user.userIdentifier }}</span>
            </div>
        {% endif %}

        {% include '@BeaconAdmin/notification/bell.html.twig' with { unreadCountUrl: path('beacon_admin_notifications_unread_count') } %}
    </div>
</header>
