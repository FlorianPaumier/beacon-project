{% set trail = beacon_admin_breadcrumbs() %}
{% if trail is not empty %}
    <nav aria-label="{{ 'beacon_admin.nav.breadcrumb'|trans({}, 'beacon_admin') }}" class="beacon-breadcrumbs-nav">
        <ol class="beacon-breadcrumbs">
            {# Home link with icon #}
            <li class="beacon-breadcrumb-item">
                <a href="{{ path('beacon_admin.dashboard_locale') }}"
                   class="beacon-breadcrumb-link"
                   title="{{ 'beacon_admin.nav.dashboard'|trans({}, 'beacon_admin') }}">
                    <span class="beacon-breadcrumb-icon">&#x1F3E0;</span>
                </a>
                <span class="beacon-breadcrumb-separator" aria-hidden="true">&rsaquo;</span>
            </li>
            {% for item in trail %}
                <li class="beacon-breadcrumb-item{{ loop.last ? ' beacon-breadcrumb-item--current' : '' }}">
                    {% if not loop.last and item.url is not null %}
                        <a href="{{ item.url }}" class="beacon-breadcrumb-link">
                            {{ item.label }}
                        </a>
                    {% else %}
                        <span aria-current="page">{{ item.label }}</span>
                    {% endif %}
                    {% if not loop.last %}
                        <span class="beacon-breadcrumb-separator" aria-hidden="true">&rsaquo;</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    </nav>
{% endif %}
