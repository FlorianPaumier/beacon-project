<div class="fi-fo-field fi-fo-rich-editor">
    {% if component.label is defined and component.label is not null %}
        <label for="{{ component.name }}_input" class="fi-fo-field-label">
            {{ component.label }}
            {% if component.required is defined and component.required %}
                <span class="fi-fo-required-indicator">*</span>
            {% endif %}
        </label>
    {% endif %}

    <input type="hidden"
           id="{{ component.name }}_input"
           name="{{ component.name }}"
           value="{{ component.value ?? '' }}">

    <div class="fi-fo-rich-editor-input"
         data-beacon-tiptap
         data-input="{{ component.name }}_input"
         data-placeholder="{{ component.placeholder ?? '' }}"
         data-max-length="{{ component.maxLength ?? '' }}">
        {{ component.value ?? '' }}
    </div>

    <div class="fi-fo-rich-editor-toolbar">
        <button type="button" data-beacon-tiptap-action="toggleBold" title="Bold"><strong>B</strong></button>
        <button type="button" data-beacon-tiptap-action="toggleItalic" title="Italic"><em>I</em></button>
        <button type="button" data-beacon-tiptap-action="toggleStrike" title="Strikethrough"><s>S</s></button>
        <span class="fi-fo-rich-editor-separator"></span>
        <button type="button" data-beacon-tiptap-action="toggleHeading" data-beacon-tiptap-args='{"level":2}' title="Heading 2">H2</button>
        <button type="button" data-beacon-tiptap-action="toggleHeading" data-beacon-tiptap-args='{"level":3}' title="Heading 3">H3</button>
        <button type="button" data-beacon-tiptap-action="toggleBulletList" title="Bullet list">•</button>
        <button type="button" data-beacon-tiptap-action="toggleOrderedList" title="Ordered list">1.</button>
        <button type="button" data-beacon-tiptap-action="toggleBlockquote" title="Blockquote">"</button>
        <span class="fi-fo-rich-editor-separator"></span>
        <button type="button" data-beacon-tiptap-action="setLink" title="Link">🔗</button>
        <button type="button" data-beacon-tiptap-action="uploadImage" title="Insert image">🖼</button>
        <button type="button" data-beacon-tiptap-action="toggleCodeBlock" title="Code">&lt;/&gt;</button>
        <button type="button" data-beacon-tiptap-action="undo" title="Undo">↩</button>
        <button type="button" data-beacon-tiptap-action="redo" title="Redo">↪</button>
    </div>

    {% if component.error is defined and component.error is not null %}
        <p class="fi-fo-error">{{ component.error }}</p>
    {% endif %}
</div>
