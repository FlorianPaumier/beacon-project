<div class="beacon-empty-state-component {{ extra_classes|default('') }}"
     role="status"
     aria-live="polite">
    <div class="beacon-empty-state-component__icon">
        {% if icon is defined and icon is not empty %}
            {{ icon|raw }}
        {% else %}
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="48" height="48"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="1.5"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 aria-hidden="true">
                <path d="M3 3h18v18H3z"/>
                <path d="M3 9h18"/>
                <path d="M9 21V9"/>
            </svg>
        {% endif %}
    </div>

    <h3 class="beacon-empty-state-component__title">{{ title }}</h3>

    {% if description is defined and description is not empty %}
        <p class="beacon-empty-state-component__description">{{ description }}</p>
    {% endif %}

    {% if action_label is defined and action_label is not empty
        and action_url is defined and action_url is not empty %}
        <a href="{{ action_url }}"
           class="beacon-btn beacon-btn--primary beacon-empty-state-component__action"
           {% if action_icon is defined and action_icon is not empty %}
               data-action-icon="{{ action_icon }}"
           {% endif %}>
            {% if action_icon is defined and action_icon is not empty %}
                <span class="beacon-empty-state-component__action-icon" aria-hidden="true">
                    {{ action_icon|raw }}
                </span>
            {% endif %}
            <span>{{ action_label }}</span>
        </a>
    {% endif %}
</div>
