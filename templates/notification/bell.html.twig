<div class="beacon-notification-bell"
     data-controller="@beacon-admin/notification-bell"
     data-beacon--notification-bell-unread-count-url-value="{{ unreadCountUrl }}">
    <button type="button"
            class="beacon-notification-bell-button"
            data-action="@beacon-admin/notification-bell#toggle"
            aria-label="Notifications">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="20" height="20"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="2"
             stroke-linecap="round"
             stroke-linejoin="round"
             aria-hidden="true">
            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span class="beacon-notification-bell-badge beacon-notification-bell-badge--hidden"
              data-beacon--notification-bell-target="badge">0</span>
    </button>

    <div class="beacon-notification-bell-dropdown beacon-notification-bell-dropdown--hidden"
         data-beacon--notification-bell-target="dropdown"
         role="menu">
        <ul class="beacon-notification-bell-list" data-notification-list>
            <li class="beacon-notification-bell-empty">No new notifications</li>
        </ul>
    </div>
</div>
