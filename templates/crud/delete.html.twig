<div class="beacon-modal"
     data-controller="beacon--delete-confirm"
     data-beacon--delete-confirm-id-value="{{ entity.id }}">
    <div class="beacon-modal__backdrop"></div>
    <div class="beacon-modal__content">
        <h2 class="beacon-modal__title">Delete {{ config.entityLabel }}</h2>
        <p class="beacon-modal__text">
            Are you sure you want to delete this {{ config.entityLabel|lower }}? This action cannot be undone.
        </p>

        <form method="post"
              action="{{ path(app.current_route ~ '_delete', { id: entity.id }) }}"
              data-beacon--delete-confirm-target="form">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
            <div class="beacon-modal__actions">
                <button type="submit" class="beacon-btn beacon-btn--danger">
                    Delete
                </button>
                <button type="button" class="beacon-btn beacon-btn--secondary"
                        data-action="beacon--delete-confirm#cancel">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>
