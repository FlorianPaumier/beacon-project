{% if result.totalPages > 1 %}
    <div class="beacon-pagination">
        <div class="beacon-pagination__info">
            Showing page {{ result.currentPage }} of {{ result.totalPages }} ({{ result.totalItems }} total)
        </div>
        <div class="beacon-pagination__controls">
            {% if result.hasPreviousPage %}
                <button type="button"
                        class="beacon-btn beacon-btn--small beacon-btn--secondary"
                        data-action="beacon--datatable#goToPage"
                        data-beacon--datatable-page-param="1">
                    &laquo; First
                </button>
                <button type="button"
                        class="beacon-btn beacon-btn--small beacon-btn--secondary"
                        data-action="beacon--datatable#goToPage"
                        data-beacon--datatable-page-param="{{ result.currentPage - 1 }}">
                    &lsaquo; Previous
                </button>
            {% endif %}

            {% if result.hasNextPage %}
                <button type="button"
                        class="beacon-btn beacon-btn--small beacon-btn--secondary"
                        data-action="beacon--datatable#goToPage"
                        data-beacon--datatable-page-param="{{ result.currentPage + 1 }}">
                    Next &rsaquo;
                </button>
                <button type="button"
                        class="beacon-btn beacon-btn--small beacon-btn--secondary"
                        data-action="beacon--datatable#goToPage"
                        data-beacon--datatable-page-param="{{ result.totalPages }}">
                    Last &raquo;
                </button>
            {% endif %}
        </div>
    </div>
{% endif %}
