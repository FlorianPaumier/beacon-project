<td class="beacon-table__td beacon-table__td--actions">
    <div class="beacon-actions">
        <a href="{{ path(app.current_route ~ '_edit', { id: row.id }) }}"
           class="beacon-btn beacon-btn--small beacon-btn--secondary"
           title="Edit">
            Edit
        </a>
        <form method="post"
              action="{{ path(app.current_route ~ '_delete', { id: row.id }) }}"
              style="display:inline"
              onsubmit="return confirm('Are you sure you want to delete this item?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ row.id) }}">
            <button type="submit" class="beacon-btn beacon-btn--small beacon-btn--danger" title="Delete">
                Delete
            </button>
        </form>
    </div>
</td>
