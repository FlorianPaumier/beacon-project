<div class="beacon-bulk-actions"
     data-controller="beacon--bulk-actions"
     data-beacon--bulk-actions-target="bar"
     style="display:none">
    <span class="beacon-bulk-actions__count"
          data-beacon--bulk-actions-target="count">
        0 selected
    </span>
    <form method="post"
          action="{{ path(app.current_route ~ '_bulk') }}"
          data-beacon--bulk-actions-target="form">
        <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete') }}">
        <div data-beacon--bulk-actions-target="idsContainer"></div>
        <button type="submit"
                class="beacon-btn beacon-btn--danger beacon-btn--small"
                onclick="return confirm('Are you sure you want to delete the selected items?');">
            Delete selected
        </button>
    </form>
</div>
